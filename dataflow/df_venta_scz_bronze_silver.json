{
	"name": "df_venta_scz_bronze_silver",
	"properties": {
		"folder": {
			"name": "bronce"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ventas_scz_csv",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ventas_sc_limpio_csv",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "derivedColumn2"
				},
				{
					"name": "derivedColumn3"
				},
				{
					"name": "derivedColumn4"
				},
				{
					"name": "derivedColumn5"
				},
				{
					"name": "filter1"
				},
				{
					"name": "select1"
				},
				{
					"name": "derivedColumn6"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id_venta as string,",
				"          fecha as string,",
				"          producto as string,",
				"          cantidad as string,",
				"          precio_unitario as string,",
				"          sucursal as string,",
				"          vendedor as string,",
				"          cliente_nombre as string,",
				"          cliente_email as string,",
				"          metodo_pago as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 derive(vendedor = trim(vendedor),",
				"          cliente_nombre = trim(cliente_nombre),",
				"          producto = trim(producto)) ~> derivedColumn1",
				"derivedColumn1 derive(producto = initCap(regexReplace(producto,'\\\\s+',' '))) ~> derivedColumn2",
				"derivedColumn2 derive(sucursal = iif(in(['SCZ','Santa Cruz','Sta Cruz','santa cruz','SANTA CRUZ','Sta. Cruz','SC'],sucursal),'Santa Cruz',sucursal)) ~> derivedColumn3",
				"derivedColumn3 derive(precio_unitario = toFloat(regexReplace(toString(precio_unitario),'[^0-9.]',''))\r",
				",",
				"          cantidad = toInteger(cantidad)) ~> derivedColumn4",
				"derivedColumn4 derive(fecha = coalesce(\r",
				"    toDate(fecha,'yyyy-MM-dd'),\r",
				"    toDate(fecha,'yyyy/MM/dd'),\r",
				"    toDate(fecha,'dd/MM/yyyy'),\r",
				"    toDate(fecha,'MM-dd-yyyy'),\r",
				"    toDate(fecha,'dd-MM-yyyy'),\r",
				"    toDate(fecha,'dd-MMM-yyyy'),\r",
				"    toDate(fecha,'dd/MMM/yyyy')\r",
				"    \r",
				")) ~> derivedColumn5",
				"derivedColumn5 filter(cantidad>0 && !isNull(precio_unitario) && !isNull(fecha)) ~> filter1",
				"filter1 select(mapColumn(",
				"          id_venta,",
				"          fecha,",
				"          producto,",
				"          cantidad,",
				"          precio_unitario,",
				"          sucursal,",
				"          vendedor,",
				"          cliente_nombre,",
				"          cliente_email,",
				"          metodo_pago",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 derive(canal = 'Sucursal') ~> derivedColumn6",
				"derivedColumn6 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     partitionFileNames:['ventas_sc_limpio.csv'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> sink1"
			]
		}
	}
}